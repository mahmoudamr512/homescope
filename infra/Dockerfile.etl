FROM python:3.12-slim-bookworm

# GDAL (ogr2ogr) for geometry loading, plus unzip for shapefile archives.
# tippecanoe (tile generation) is added in the M2 tile stage.
RUN apt-get update && apt-get install -y --no-install-recommends \
      gdal-bin \
      ca-certificates \
      unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY etl /app/etl
RUN pip install --no-cache-dir -e "/app/etl[dev]"

WORKDIR /app/etl
CMD ["python", "-m", "homescope_etl", "--help"]
