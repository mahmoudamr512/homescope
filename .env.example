# Postgres / PostGIS
POSTGRES_USER=homescope
POSTGRES_PASSWORD=homescope
POSTGRES_DB=homescope
# Host port for local Postgres (container port stays 5432). Default avoids the
# common 5432 collision with other local databases.
POSTGRES_PORT=5433
DATABASE_URL=postgresql://homescope:homescope@localhost:5433/homescope

# Optional: base URL where PMTiles are hosted (CDN/object storage). Defaults to
# the app's own /tiles directory when unset.
# NEXT_PUBLIC_TILES_URL=https://cdn.example.com/homescope/tiles

# Optional: author photo for the "How it's built" page. A path (drop the file at
# apps/web/public/mahmoud-amr.jpg) or a full URL. Falls back to an initials avatar.
# NEXT_PUBLIC_AUTHOR_PHOTO=/mahmoud-amr.jpg
